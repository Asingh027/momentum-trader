# Copy to .env and fill in values before running

# ── Capital & Sizing ───────────────────────────────────────────────
PAPER_CAPITAL=25000.0
TARGET_POSITION_PCT=0.20         # 20% of portfolio per position
MAX_POSITIONS=5
CASH_FLOOR_PCT=0.10              # Always hold >= 10% cash

# ── Universe Filters ──────────────────────────────────────────────
MIN_MARKET_CAP=5_000_000_000     # $5B
MIN_PRICE=20.0
MAX_PRICE=500.0
MIN_ADDV=50_000_000              # $50M avg daily dollar volume (20d)

# ── Entry Signal Thresholds ───────────────────────────────────────
TREND_SMA_PERIOD=200             # Long-term trend filter
PULLBACK_LOOKBACK=10             # Days to look back for high
PULLBACK_PCT=0.05                # Down >= 5% from 10d high
RSI_PERIOD=14
RSI_OVERSOLD=30
VOLUME_RATIO=1.5                 # Today vol >= 1.5x 20d avg
VOLUME_AVG_PERIOD=20
EARNINGS_BUFFER_DAYS=5           # Skip if earnings within 5 days

# ── Exit Thresholds ───────────────────────────────────────────────
PROFIT_TARGET_PCT=0.10           # +10% from entry
STOP_LOSS_PCT=0.05               # -5% from entry
TIME_STOP_DAYS=10                # Exit after 10 trading days
SPY_TREND_SMA_PERIOD=200         # SPY regime SMA

# ── Transaction Costs ─────────────────────────────────────────────
COMMISSION=0.0
SLIPPAGE_BPS=5                   # 5 bps per side

# ── Backtest Window ───────────────────────────────────────────────
BACKTEST_START=2021-04-01
BACKTEST_END=2026-04-01

# ── Walk-Forward ──────────────────────────────────────────────────
WF_IS_YEARS=2                    # In-sample window (years)
WF_OOS_MONTHS=6                  # Out-of-sample window (months)
WF_STEP_MONTHS=3                 # Advance step (quarterly)

# ── Data / Caching ────────────────────────────────────────────────
DATA_DIR=data
OUTPUTS_DIR=outputs
