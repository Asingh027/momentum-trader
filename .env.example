# Strategy config — Aggressive paper-trading profile
# Alpaca credentials are NOT here; they live at:
#   C:\Users\Avneet\Documents\Trading Helper\alpaca.env

# ── Position sizing ───────────────────────────────────────────────────────
TARGET_POSITION_PCT=0.20   # 20% of portfolio per position
MAX_POSITIONS=4            # max concurrent positions
CASH_FLOOR_PCT=0.20        # keep >= 20% cash at all times

# ── Optional path overrides ───────────────────────────────────────────────
# These default to the Trading Helper folder on Windows. Override for Docker
# or alternate installations. Docker values are set in docker-compose.yml.
#
# ALPACA_ENV_PATH=C:\Users\Avneet\Documents\Trading Helper\alpaca.env
# DB_PATH=C:\Users\Avneet\Documents\Trading Helper\trader.db
# REPORTS_DIR=C:\Users\Avneet\Documents\Trading Helper\daily_reports
